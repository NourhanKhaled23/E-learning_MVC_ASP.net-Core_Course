@model WebApplication1.Models.ViewModels.EnrollStudentViewModel

@{
    ViewData["Title"] = "Enroll Student";
}

<div class="container mt-4">
    <div class="card shadow border-0 col-md-8 mx-auto bg-white">
        <div class="card-header bg-theme text-white">
            <h4 class="mb-0"><i class="fas fa-plus-circle me-2"></i> Enroll @Model.StudentName in Course</h4>
        </div>
        <div class="card-body p-5">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0"></div>
                <input type="hidden" asp-for="StudentSsn" />
                <input type="hidden" asp-for="StudentName" />

                <div class="row g-4">
                    <div class="col-md-12">
                        <label asp-for="CourseId" class="form-label fw-bold text-gray-800">Select Course</label>
                        <select asp-for="CourseId" class="form-select border-theme" asp-items="ViewBag.Courses">
                            <option value="">-- Choose a Course --</option>
                        </select>
                        <span asp-validation-for="CourseId" class="text-danger small fw-semibold"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Degree" class="form-label fw-bold text-gray-800">Final Score (Degree)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="fas fa-graduation-cap text-theme"></i></span>
                            <input asp-for="Degree" class="form-control" type="number" step="0.5" placeholder="0 - 100" />
                        </div>
                        <span asp-validation-for="Degree" class="text-danger small fw-semibold"></span>
                        <div class="form-text mt-2"><i class="fas fa-info-circle me-1"></i> This degree will be compared against the course minimum to determine pass/fail status.</div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                    <a asp-controller="Student" asp-action="Details" asp-route-id="@Model.StudentSsn" class="btn btn-outline-secondary px-4">Back to Details</a>
                    <button type="submit" class="btn btn-theme px-5 shadow-sm fw-bold">Submit Enrollment</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
