@model WebApplication1.Models.Enrollment

@{
    ViewData["Title"] = "Unenroll Student";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-7 border rounded shadow-lg p-5 bg-white">
        <h2 class="text-danger text-center"><i class="fas fa-user-minus me-2"></i> Unenroll Student</h2>
        <h4 class="text-center mb-5 text-warning fw-bold">Are you sure you want to unenroll this student from the course?</h4>
        <p class="text-center text-muted mb-4 fs-5">All course progress and degrees will be permanently removed.</p>
        <hr />
        <div class="alert alert-light border-2 px-4 shadow-sm">
            <dl class="row mb-0">
                <dt class="col-sm-5 text-secondary fs-5 py-2">Student Name</dt>
                <dd class="col-sm-7 fw-bold fs-5 py-2">@(Model.Student?.Name ?? "Loading...")</dd>

                <dt class="col-sm-5 text-secondary fs-5 py-2 border-top">Course Name</dt>
                <dd class="col-sm-7 fw-bold fs-5 py-2 border-top">@(Model.Course?.Name ?? "Loading...")</dd>

                <dt class="col-sm-5 text-secondary fs-5 py-2 border-top">Current Degree</dt>
                <dd class="col-sm-7 fs-5 py-2 border-top border-bottom text-theme">@Model.Degree%</dd>
            </dl>
        </div>
        
        <div class="mt-5 d-flex justify-content-between align-items-center px-2">
            <a asp-controller="Student" asp-action="Details" asp-route-id="@Model.StudentSsn" 
               class="btn btn-outline-secondary rounded-pill px-5 py-2 shadow-sm fw-bold">
                <i class="fas fa-arrow-left me-2"></i> Cancel
            </a>
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="StudentSsn" />
                <input type="hidden" asp-for="CourseId" />
                <button type="submit" class="btn btn-danger rounded-pill px-5 py-2 shadow-sm fw-bold border-2">
                    <i class="fas fa-trash-alt me-2 text-white"></i> Confirm Unenroll
                </button>
            </form>
        </div>
    </div>
</div>
