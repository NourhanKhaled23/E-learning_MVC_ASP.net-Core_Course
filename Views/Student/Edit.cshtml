@model WebApplication1.Models.ViewModels.StudentEditViewModel

@{
    ViewData["Title"] = "Edit Student";
}

<div class="container mt-4">
    <div class="card shadow border-0 col-md-8 mx-auto bg-white">
        <div class="card-header bg-theme text-white">
            <h4 class="mb-0"><i class="fas fa-user-edit me-2"></i> Edit Student Profile</h4>
        </div>
        <div class="card-body p-5">
            <form asp-action="Edit" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Ssn" />
                <input type="hidden" asp-for="ExistingImage" />

                <div class="row g-4">
                    <partial name="_StudentForm" />

                    <div class="col-12 mt-4 pt-3 border-top">
                        <label asp-for="ImageFile" class="form-label control-label fw-bold text-gray-800">Update Profile Picture</label>
                        <input asp-for="ImageFile" type="file" class="form-control border-theme border-opacity-50" />
                        <span asp-validation-for="ImageFile" class="text-danger small"></span>
                        <div class="mt-2 text-muted small"><i class="fas fa-image me-1"></i> Current image target: <code>@Model.ExistingImage</code> (Upload to replace)</div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-5 border-top pt-4">
                    <a asp-action="GetAll" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-theme px-5 shadow-sm fw-bold">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
