@model WebApplication1.Models.CreateStudentViewModel

@{
    ViewData["Title"] = "Create Student";
}

<div class="container mt-4">
    <div class="card shadow border-0 col-md-8 mx-auto bg-white">
        <div class="card-header bg-theme text-white">
            <h4 class="mb-0"><i class="fas fa-user-plus me-2"></i> Register New Student</h4>
        </div>
        <div class="card-body p-5">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0"></div>
                
                <div class="row g-4">
                    <partial name="_StudentForm" />
                </div>

                <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                    <a asp-action="GetAll" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-theme px-5 shadow-sm fw-bold">Register Student</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
