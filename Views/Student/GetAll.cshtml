@model IEnumerable<WebApplication1.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h2>All Students</h2>
        <a asp-action="Create" class="btn btn-success">
            Add New Student
        </a>
    </div>
    <div class="card-body">
        
        <div class="alert alert-info border-2">
            <h5 class="mb-3"><i class="bi bi-info-circle me-2"></i>State Management Examples</h5>
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="p-2 border rounded bg-light">
                        <strong>1. ViewData</strong><br/>
                        <small class="text-muted">Dictionary-based (requires casting):</small><br/>
                        <span class="text-primary">Page: @ViewData["Title"]</span><br/>
                        <span class="text-primary">Time: @ViewData["ServerTime"]</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-2 border rounded bg-light">
                        <strong>2. ViewBag</strong><br/>
                        <small class="text-muted">Dynamic property (no casting):</small><br/>
                        <span class="text-primary">Total Students: @ViewBag.StudentCount</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-2 border rounded bg-light">
                        <strong>4. Session</strong><br/>
                        <small class="text-muted">Persists across requests:</small><br/>
                        <span class="text-primary">Last Viewed: @(ViewBag.LastViewedStudent ?? "None yet")</span>
                    </div>
                </div>
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div style="background-color: #d4edda; color: #155724; padding: 10px; border-radius: 5px; margin-bottom: 15px;">
               <strong>Status:</strong> @TempData["Success"]
            </div>
        }
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-bordered table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>SSN</th>
                            <th>Name</th>
                            <th>Age</th>
                            <th>Address</th>
                            <th>Email</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in Model)
                        {
                            <tr>
                                <td><span class="badge">@student.Ssn</span></td>
                                <td>@student.Name</td>
                                <td>@student.Age years</td>
                                <td>@student.Address</td>
                                <td>@student.Email</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@student.Ssn"
                                       class="btn btn-sm btn-info">
                                        View Details
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <h4>No Students Found</h4>
                <p class="text-muted">Start by adding your first student to the system.</p>
                <a asp-action="Create" class="btn btn-theme">
                    Add First Student
                </a>
            </div>
        }
    </div>
</div>
