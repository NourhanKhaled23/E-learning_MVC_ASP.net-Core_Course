@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4 fw-bold text-dark mb-3">Welcome to <span class="text-theme">EduPlatform</span></h1>
    <p class="lead text-muted mb-5">Nourhan Khaled MVC Labs from ITI Course</p>
    
    <div class="row g-4 mt-2">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 bg-white hover-shadow transition">
                <div class="card-body p-4 text-center">
                    <div class="mb-3">
                        <i class="fas fa-user-graduate fa-3x text-theme"></i>
                    </div>
                    <h5 class="card-title fw-bold">Students</h5>
                    <p class="card-text text-muted">Manage enrollments, grades, and profile information seamlessly.</p>
                </div>
                <div class="card-footer bg-transparent border-0 pb-4 text-center">
                    <a asp-controller="Student" asp-action="GetAll" class="btn btn-theme px-4 mb-2"><i class="fas fa-folder-open me-2"></i>View All</a>
                    <a asp-controller="Student" asp-action="Create" class="btn btn-outline-secondary px-4 mb-2"><i class="fas fa-plus me-2"></i>Add New</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 bg-white">
                <div class="card-body p-4 text-center">
                    <div class="mb-3">
                        <i class="fas fa-building fa-3x text-theme"></i>
                    </div>
                    <h5 class="card-title fw-bold">Departments</h5>
                    <p class="card-text text-muted">Structure and organize academic resources and instructors.</p>
                </div>
                <div class="card-footer bg-transparent border-0 pb-4 text-center">
                    <a asp-controller="Department" asp-action="GetAll" class="btn btn-theme px-4 mb-2"><i class="fas fa-folder-open me-2"></i>View All</a>
                    <a asp-controller="Department" asp-action="Create" class="btn btn-outline-secondary px-4 mb-2"><i class="fas fa-plus me-2"></i>Add New</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 bg-white">
                <div class="card-body p-4 text-center">
                    <div class="mb-3">
                        <i class="fas fa-book-open fa-3x text-theme"></i>
                    </div>
                    <h5 class="card-title fw-bold">Courses</h5>
                    <p class="card-text text-muted">Define curriculum, syllabuses, and graduation thresholds.</p>
                </div>
                <div class="card-footer bg-transparent border-0 pb-4 text-center">
                    <a asp-controller="Course" asp-action="GetAll" class="btn btn-theme px-4 mb-2"><i class="fas fa-folder-open me-2"></i>View All</a>
                    <a asp-controller="Course" asp-action="Create" class="btn btn-outline-secondary px-4 mb-2"><i class="fas fa-plus me-2"></i>Add New</a>
                </div>
            </div>
        </div>
    </div>
</div>
