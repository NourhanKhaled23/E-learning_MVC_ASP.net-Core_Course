@model WebApplication1.Models.Department

@{
    ViewData["Title"] = "Delete Department";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 border rounded shadow p-4 bg-white">
        <h2 class="text-danger text-center"><i class="fas fa-trash-alt me-2"></i> Delete Department</h2>
        <h4 class="text-center mb-4 text-warning">Are you sure you want to delete this department?</h4>
        <p class="text-center text-muted">A warning: all students and instructors in this department will be affected by this operation.</p>
        <hr />
        <dl class="row">
            <dt class="col-sm-4 text-secondary">Department Name</dt>
            <dd class="col-sm-8 fw-bold">@Model.Name</dd>

            <dt class="col-sm-4 text-secondary">Location</dt>
            <dd class="col-sm-8">@Model.Location</dd>

            <dt class="col-sm-4 text-secondary">Phone Number</dt>
            <dd class="col-sm-8 fw-bold">@Model.PhoneNumber</dd>
        </dl>
        
        <div class="mt-4 d-flex justify-content-between align-items-center px-2">
            <a asp-action="GetAll" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-bold">
                <i class="fas fa-arrow-left me-1"></i> Cancel
            </a>
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="DeptId" name="id" />
                <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm fw-bold">
                    <i class="fas fa-trash-alt me-2"></i> Confirm Delete
                </button>
            </form>
        </div>
    </div>
</div>
