@model WebApplication1.Models.Department

@{
    ViewData["Title"] = "Department Details";
}

<div class="card">
    <div class="card-header">
        <h2>Department Details</h2>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <h4>Department Information</h4>
                <table class="table table-bordered">
                    <tr>
                        <th style="width: 30%;">ID</th>
                        <td><span class="badge">@Model.DeptId</span></td>
                    </tr>
                    <tr>
                        <th>Name</th>
                        <td>@Model.Name</td>
                    </tr>
                    <tr>
                        <th>Location</th>
                        <td>@Model.Location</td>
                    </tr>
                    <tr>
                        <th>Phone Number</th>
                        <td>@Model.PhoneNumber</td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-md-6">
                <h4>Students (@Model.Students.Count)</h4>
                @if (Model.Students.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered">
                            <thead class="table-dark">
                                <tr>
                                    <th style="width: 15%;">SSN</th>
                                    <th style="width: 45%;">Name</th>
                                    <th style="width: 40%;">Email</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var student in Model.Students)
                                {
                                    <tr>
                                        <td>@student.Ssn</td>
                                        <td>@student.Name</td>
                                        <td>@student.Email</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No students assigned to this department.</p>
                }
            </div>
            
            <div class="col-md-6">
                <h4>Instructors (@Model.Instructors.Count)</h4>
                @if (Model.Instructors.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered">
                            <thead class="table-dark">
                                <tr>
                                    <th style="width: 15%;">ID</th>
                                    <th style="width: 45%;">Name</th>
                                    <th style="width: 40%;">Email</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var instructor in Model.Instructors)
                                {
                                    <tr>
                                        <td>@instructor.InsId</td>
                                        <td>@instructor.Name</td>
                                        <td>@instructor.Email</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No instructors assigned to this department.</p>
                }
            </div>
        </div>

        <div class="mt-4">
            <a asp-action="GetAll" class="btn btn-secondary">
                Back to Departments
            </a>
        </div>
    </div>
</div>