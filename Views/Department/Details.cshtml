@model WebApplication1.Models.Department

@{
    ViewData["Title"] = "Department Details";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12 text-center text-md-start">
            <h2 class="fw-bold mb-3"><i class="fas fa-building text-theme me-2"></i> @Model.Name Department</h2>
            <div class="d-flex flex-wrap gap-3 mb-4">
                <span class="badge bg-light text-dark shadow-sm border p-2"><i class="fas fa-fingerprint text-theme me-1"></i> ID: @Model.DeptId</span>
                <span class="badge bg-light text-dark shadow-sm border p-2"><i class="fas fa-map-marker-alt text-theme me-1"></i> @Model.Location</span>
                <span class="badge bg-light text-dark shadow-sm border p-2"><i class="fas fa-phone text-theme me-1"></i> @Model.PhoneNumber</span>
            </div>
            <div>
                <a asp-action="Edit" asp-route-id="@Model.DeptId" class="btn btn-theme px-4 shadow-sm"><i class="fas fa-edit me-1"></i>Edit Department</a>
                <a asp-action="GetAll" class="btn btn-outline-secondary px-4 shadow-sm ms-2"><i class="fas fa-arrow-left me-1"></i>Back to List</a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            @{
                ViewBag.TableTitle = "Enrolled Students";
                ViewBag.TableIcon = "fa-users";
                ViewBag.IdProperty = "Ssn";
                ViewBag.TableColor = "bg-theme";
            }
            <partial name="_MemberTable" model="Model.Students" />
        </div>
        
        <div class="col-lg-6">
            @{
                ViewBag.TableTitle = "Assigned Instructors";
                ViewBag.TableIcon = "fa-user-tie";
                ViewBag.IdProperty = "InsId";
                ViewBag.TableColor = "bg-secondary";
            }
            <partial name="_MemberTable" model="Model.Instructors" />
        </div>
    </div>
</div>
