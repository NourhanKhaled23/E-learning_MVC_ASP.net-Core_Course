@model IEnumerable<WebApplication1.Models.Department>

@{
    ViewData["Title"] = "Departments";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center bg-transparent border-0 pt-4 px-4">
        <h2 class="mb-0 text-theme fw-bold">All Departments</h2>
        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">
                <i class="fas fa-plus me-1"></i> Add New
            </a>
            <a asp-action="AddV2" class="btn btn-outline-theme rounded-pill px-4 shadow-sm border-2 fw-bold">
                <i class="fas fa-star me-1"></i> Add V2
            </a>
        </div>
    </div>
    <div class="card-body">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }
        
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-bordered table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Location</th>
                            <th>Phone Number</th>
                            <th>Students Count</th>
                            <th>Instructors Count</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var department in Model)
                        {
                            <tr>
                                <td><span class="badge">@department.DeptId</span></td>
                                <td>@department.Name</td>
                                <td>@department.Location</td>
                                <td>@department.PhoneNumber</td>
                                <td><span class="badge">@department.Students.Count</span></td>
                                <td><span class="badge">@department.Instructors.Count</span></td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@department.DeptId"
                                       class="btn btn-sm btn-info">
                                        View Details
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <h4>No Departments Found</h4>
                <p class="text-muted">Start by adding your first department to the system.</p>
                <a asp-action="Create" class="btn btn-theme">
                    Add First Department
                </a>
            </div>
        }
    </div>
</div>
