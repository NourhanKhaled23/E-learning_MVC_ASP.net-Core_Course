@model WebApplication1.Models.Instructor

@{
    ViewData["Title"] = "Delete Instructor";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 border rounded shadow p-4 bg-white">
        <h2 class="text-danger text-center"><i class="fas fa-trash-alt me-2"></i> Delete Instructor</h2>
        <h4 class="text-center mb-4">Are you sure you want to delete this instructor?</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-4">Full Name</dt>
            <dd class="col-sm-8 fw-bold">@Model.Name</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8 text-break">@Model.Email</dd>

            <dt class="col-sm-4">Salary</dt>
            <dd class="col-sm-8 badge bg-info fs-6">@Model.Salary.ToString("C")</dd>
            
            <dt class="col-sm-4">Address</dt>
            <dd class="col-sm-8">@(Model.Address ?? "N/A")</dd>
        </dl>
        
        <div class="mt-4 d-flex justify-content-between align-items-center">
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
                <i class="fas fa-arrow-left me-1"></i> Cancel
            </a>
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="InsId" name="id" />
                <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm">
                    <i class="fas fa-trash-alt me-1"></i> Confirm Delete
                </button>
            </form>
        </div>
    </div>
</div>
