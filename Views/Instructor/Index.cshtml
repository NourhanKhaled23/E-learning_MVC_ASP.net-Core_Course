@model IEnumerable<WebApplication1.Models.Instructor>

@{
    ViewData["Title"] = "Instructors List";
}

<h1>Instructors</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Salary</th>
            <th>Department</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.Name</td>
                <td>@item.Email</td>
                <td>@item.Salary</td>
                <td>@(item.Department?.Name ?? "N/A")</td>
                <td>
                    <div class="btn-group">
                        <a asp-action="Edit" asp-route-id="@item.InsId" class="btn btn-sm btn-info">Edit</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Delete" asp-route-id="@item.InsId" class="btn btn-sm btn-danger">Delete</a>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
