@model WebApplication1.Models.ViewModels.StudentDetailsViewModel

<div class="card shadow border-0">
    <div class="card-body text-center">
        <div class="position-relative d-inline-block">
            <img src="~/images/@Model.Image" alt="@Model.Name" class="rounded-circle mb-3 border border-3 border-theme" style="width: 150px; height: 150px; object-fit: cover;"/>
            <span class="position-absolute bottom-0 end-0 p-2 badge rounded-circle bg-success shadow" style="border: 2px solid white;"><i class="fas fa-check fa-xs"></i></span>
        </div>
        <h4 class="card-title fw-bold">@Model.Name</h4>
        <span class="badge bg-secondary mb-2 px-3 py-2 rounded-pill shadow-sm">@Model.DepartmentName</span>
        
        <ul class="list-unstyled text-start mt-4 border-top pt-4">
            <li class="mb-3 d-flex align-items-center">
                <div class="btn-theme p-2 rounded-circle me-3 shadow-sm" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-id-card fa-xs"></i>
                </div>
                <div>
                    <small class="text-muted d-block lh-1">National ID (SSN)</small>
                    <span class="fw-bold text-dark">@Model.Ssn</span>
                </div>
            </li>
            <li class="mb-3 d-flex align-items-center">
                <div class="btn-theme p-2 rounded-circle me-3 shadow-sm" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-envelope fa-xs"></i>
                </div>
                <div>
                    <small class="text-muted d-block lh-1">Email Address</small>
                    <span class="fw-bold text-dark">@Model.Email</span>
                </div>
            </li>
            <li class="mb-3 d-flex align-items-center">
                <div class="bg-info-subtle text-info p-2 rounded-circle me-3 shadow-sm" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-map-marker-alt fa-xs"></i>
                </div>
                <div>
                    <small class="text-muted d-block lh-1">Residential Address</small>
                    <span class="fw-bold text-dark">@Model.Address</span>
                </div>
            </li>
            <li class="mb-3 d-flex align-items-center">
                <div class="bg-warning-subtle text-warning p-2 rounded-circle me-3 shadow-sm" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-calendar-alt fa-xs"></i>
                </div>
                <div>
                    <small class="text-muted d-block lh-1">Age</small>
                    <span class="fw-bold text-dark">@Model.Age Years</span>
                </div>
            </li>
        </ul>
        
        <div class="mt-4 pt-3 border-top d-flex justify-content-center gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Ssn" class="btn btn-theme px-4 shadow-sm"><i class="fas fa-edit me-1"></i>Edit Profile</a>
            <a asp-action="GetAll" class="btn btn-outline-secondary px-4"><i class="fas fa-arrow-left me-1"></i>Back</a>
        </div>
    </div>
</div>
