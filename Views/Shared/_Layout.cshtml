<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduPlatform</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --pink-base: #e83e8c;
            --pink-hover: #c22971;
            --gray-dark: #343a40;
            --gray-light: #f8f9fc;
        }
        body { background-color: var(--gray-light); }
        .text-theme { color: var(--pink-base) !important; }
        .bg-theme { background-color: var(--pink-base) !important; color: white !important; }
        .btn-theme { background-color: var(--pink-base); color: white; border: none; }
        .btn-theme:hover { background-color: var(--pink-hover); color: white; }
        .border-theme { border-color: var(--pink-base) !important; }
        
        .navbar { box-shadow: 0 .15rem 1.75rem 0 rgba(58,59,69,.15); }
        .footer { padding-top: 1.5rem; padding-bottom: 1.5rem; background-color: #fff; box-shadow: 0 -.15rem 1.75rem 0 rgba(58,59,69,.15); border-top: 1px solid #e3e6f0; }
        .dropdown-menu { border-radius: 0.35rem; }
        .btn-white { background-color: #fff; color: var(--pink-base); border: 1px solid #fff; }
        .btn-white:hover { background-color: #f8f9fa; color: var(--pink-hover); }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom mb-4 static-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-graduation-cap fa-lg text-theme me-2"></i>
                    <span class="fs-4 fw-bold text-theme">EduPlatform</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent"
                        aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 fw-semibold">
                        <li class="nav-item me-2">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1 text-muted"></i> Home
                            </a>
                        </li>
                        <li class="nav-item dropdown me-2">
                            <a class="nav-link dropdown-toggle" href="#" id="studentsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-user-graduate me-1 text-muted"></i> Students
                            </a>
                            <ul class="dropdown-menu shadow border-0" aria-labelledby="studentsDropdown">
                                <li><a class="dropdown-item" asp-controller="Student" asp-action="GetAll"><i class="fas fa-list me-2 text-muted"></i>All Students</a></li>
                                <li><a class="dropdown-item" asp-controller="Student" asp-action="Create"><i class="fas fa-plus me-2 text-muted"></i>Add Student</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown me-2">
                            <a class="nav-link dropdown-toggle" href="#" id="departmentsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-building me-1 text-muted"></i> Departments
                            </a>
                            <ul class="dropdown-menu shadow border-0" aria-labelledby="departmentsDropdown">
                                <li><a class="dropdown-item" asp-controller="Department" asp-action="GetAll"><i class="fas fa-list me-2 text-muted"></i>All Departments</a></li>
                                <li><a class="dropdown-item" asp-controller="Department" asp-action="Create"><i class="fas fa-plus me-2 text-muted"></i>Add Department</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown me-2">
                            <a class="nav-link dropdown-toggle" href="#" id="coursesDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-book me-1 text-muted"></i> Courses
                            </a>
                            <ul class="dropdown-menu shadow border-0" aria-labelledby="coursesDropdown">
                                <li><a class="dropdown-item" asp-controller="Course" asp-action="GetAll"><i class="fas fa-list me-2 text-muted"></i>All Courses</a></li>
                                <li><a class="dropdown-item" asp-controller="Course" asp-action="Create"><i class="fas fa-plus me-2 text-muted"></i>Add Course</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-auto">
        <div class="container text-center">
            <span class="text-muted"><i class="fas fa-code me-1"></i> &copy; 2026 - EduPlatform - Built with ASP.NET Core MVC</span>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
