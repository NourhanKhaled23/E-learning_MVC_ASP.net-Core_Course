<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nourhan Tasks</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --pink-base: #e83e8c;
            --pink-hover: #c22971;
            --gray-dark: #343a40;
            --gray-light: #f8f9fc;
        }
        body { background-color: var(--gray-light); }
        .text-theme { color: var(--pink-base) !important; }
        .bg-theme { background-color: var(--pink-base) !important; color: white !important; }
        .btn-theme { background-color: var(--pink-base); color: white; border: none; }
        .btn-theme:hover { background-color: var(--pink-hover); color: white; }
        .border-theme { border-color: var(--pink-base) !important; }
        
        .navbar { box-shadow: 0 .15rem 1.75rem 0 rgba(58,59,69,.15); }
        .footer { padding-top: 1.5rem; padding-bottom: 1.5rem; background-color: #fff; box-shadow: 0 -.15rem 1.75rem 0 rgba(58,59,69,.15); border-top: 1px solid #e3e6f0; }
        .dropdown-menu { border-radius: 0.35rem; }
        .btn-white { background-color: #fff; color: var(--pink-base); border: 1px solid #fff; }
        .btn-white:hover { background-color: #f8f9fa; color: var(--pink-hover); }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <partial name="_Navbar" />
    </header>
    
    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            <partial name="_Notifications" />
            @RenderBody()
        </main>
    </div>

    <partial name="_Footer" />
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
