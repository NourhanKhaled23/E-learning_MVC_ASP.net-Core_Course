@model dynamic

@{
    var title = ViewBag.TableTitle ?? "Members";
    var icon = ViewBag.TableIcon ?? "fa-users";
    var idProp = ViewBag.IdProperty ?? "Id";
    var colorClass = ViewBag.TableColor ?? "bg-theme";
    var count = Enumerable.Count(Model);
}

<div class="card shadow border-0 h-100">
    <div class="card-header @colorClass text-white d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0"><i class="fas @icon me-2"></i> @title</h5>
        <span class="badge bg-white text-dark rounded-pill px-3 py-1 fw-bold shadow-sm">@count</span>
    </div>
    <div class="card-body p-0">
        @if (count > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="px-4 py-3 border-0">ID</th>
                            <th class="py-3 border-0">Name</th>
                            <th class="py-3 border-0">Email Address</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var person in Model)
                        {
                            <tr>
                                <td class="px-4"><span class="badge bg-light text-muted border px-2 py-1">@(person.GetType().GetProperty(idProp)?.GetValue(person, null) ?? "N/A")</span></td>
                                <td class="fw-bold text-dark">@person.Name</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light rounded-circle p-2 me-2" style="width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;">
                                            <i class="fas fa-envelope fa-xs text-muted"></i>
                                        </div>
                                        <a href="mailto:@person.Email" class="text-decoration-none text-muted small fw-semibold">@person.Email</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <div class="empty-state text-center py-5">
                    <div class="mb-3 text-muted">
                        <i class="fas @(icon.Replace("fa-", "fa-slash-")) display-4 opacity-25"></i>
                    </div>
                    <p class="text-muted mb-0">No @title.ToLower() found in this department.</p>
                </div>
            </div>
        }
    </div>
</div>
