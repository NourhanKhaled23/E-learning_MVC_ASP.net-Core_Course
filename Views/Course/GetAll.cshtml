@model IEnumerable<WebApplication1.Models.ViewModels.CourseViewModel>

@{
    ViewData["Title"] = "Courses";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Courses</h1>
        <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="fas fa-plus fa-sm text-white-50"></i> Create New</a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.Name)</th>
                            <th>@Html.DisplayNameFor(model => model.Description)</th>
                            <th>@Html.DisplayNameFor(model => model.Topics)</th>
                            <th>@Html.DisplayNameFor(model => model.MinDegree)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr>
                                <td><span class="fw-bold">@Html.DisplayFor(modelItem => item.Name)</span></td>
                                <td>@Html.DisplayFor(modelItem => item.Description)</td>
                                <td>@Html.DisplayFor(modelItem => item.Topics)</td>
                                <td><span class="badge bg-info text-dark">@Html.DisplayFor(modelItem => item.MinDegree)</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
