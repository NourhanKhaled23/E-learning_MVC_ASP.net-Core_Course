@model IEnumerable<WebApplication1.Models.ViewModels.CourseViewModel>

@{
    ViewData["Title"] = "Courses";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Courses</h1>
        <a asp-action="Create" class="btn btn-theme shadow-sm"><i class="fas fa-plus fa-sm text-white-50"></i> Create New</a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header bg-white py-3">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h6 class="m-0 font-weight-bold text-theme"><i class="fas fa-search me-1"></i> Quick Search</h6>
                </div>
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-theme text-white border-0"><i class="fas fa-filter"></i></span>
                        <input type="text" id="courseSearch" class="form-control border-left-0 shadow-none" placeholder="Search by name or description..." />
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div id="courseTableContainer">
                <partial name="_CourseTable" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#courseSearch").on("keyup", function () {
                var value = $(this).val();
                $.ajax({
                    url: '@Url.Action("GetAll", "Course")',
                    data: { search: value },
                    headers: { "X-Requested-With": "XMLHttpRequest" },
                    success: function (data) {
                        $("#courseTableContainer").html(data);
                    }
                });
            });
        });
    </script>
}
