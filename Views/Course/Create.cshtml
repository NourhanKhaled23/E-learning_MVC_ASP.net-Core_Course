@model WebApplication1.Models.ViewModels.CourseViewModel

@{
    ViewData["Title"] = "Create Course";
}

<div class="container mt-4">
    <div class="card shadow border-0 col-md-8 mx-auto">
        <div class="card-header bg-theme text-white">
            <h4 class="mb-0">Create New Course</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                
                <div class="row g-3">
                    <partial name="_CourseForm" />
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="GetAll" class="btn btn-outline-secondary">Back to List</a>
                    <button type="submit" class="btn btn-theme px-4">Create Course</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
