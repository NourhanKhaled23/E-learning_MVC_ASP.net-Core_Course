@model WebApplication1.Models.Course

@{
    ViewData["Title"] = "Delete Course";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 border rounded shadow p-4 bg-white">
        <h2 class="text-danger text-center"><i class="fas fa-trash-alt me-2"></i> Delete Course</h2>
        <h4 class="text-center mb-4 text-warning">Are you sure you want to delete this course?</h4>
        <p class="text-center text-muted">All students enrolled in this course will have their enrollment removed permanently.</p>
        <hr />
        <dl class="row">
            <dt class="col-sm-4 text-secondary">Course Name</dt>
            <dd class="col-sm-8 fw-bold">@Model.Name</dd>

            <dt class="col-sm-4 text-secondary">Topics</dt>
            <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Topics) ? "N/A" : Model.Topics)</dd>

            <dt class="col-sm-4 text-secondary">Min Degree</dt>
            <dd class="col-sm-8 fw-bold badge bg-theme fs-6">@Model.MinDegree%</dd>
        </dl>
        
        <div class="mt-4 d-flex justify-content-between align-items-center px-2">
            <a asp-action="GetAll" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-bold">
                <i class="fas fa-arrow-left me-1"></i> Cancel
            </a>
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="CrsId" name="id" />
                <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm fw-bold">
                    <i class="fas fa-trash-alt me-2"></i> Confirm Delete
                </button>
            </form>
        </div>
    </div>
</div>
