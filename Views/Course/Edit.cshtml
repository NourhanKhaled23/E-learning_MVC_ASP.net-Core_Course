@model WebApplication1.Models.ViewModels.CourseViewModel

@{
    ViewData["Title"] = "Edit Course";
}

<div class="container mt-4">
    <div class="card shadow border-0 col-md-8 mx-auto">
        <div class="card-header bg-theme text-white">
            <h4 class="mb-0">Edit Course: @Model.Name</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="CrsId" />

                <div class="row g-3">
                    <partial name="_CourseForm" />
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                    <a asp-action="GetAll" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-theme px-4">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
